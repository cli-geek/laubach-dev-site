---
const year = new Date().getFullYear();
---
<footer class="footer-container">
    <p>© {year} Austin Laubach</p>
    <ul class="links-container">
        <li class="link">
            <a href="https://github.com/cli-geek" target="_blank" rel="noopener noreferrer">GitHub</a>
        </li>
        <li class="link">
            <a href="https://www.linkedin.com/in/austinlaubach/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </li>
        <li class="link">
            <a href="/contact">Contact</a>
        </li>
    </ul>
</footer>
<style>
    .footer-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;

        margin-top: var(--space-8);
        padding: var(--space-2) var(--space-2);
        border-top: 1px solid var(--color-border);

        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }

    .links-container {
        display: flex;

        padding: 0px;
        gap: var(--space-4);

        list-style: none;

        color: inherit;
    }

    .links-container a {
        color: inherit;
        text-decoration: none;
        transition: color 0.15s ease;
    }

    .links-container a:hover {
        color: var(--color-text);
    }

</style>