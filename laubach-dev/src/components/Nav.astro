---
const currentPath = Astro.url.pathname;
---
<nav aria-label="Primary">
    <div class="container">
        <a class="wordmark" href="/" aria-current={currentPath === "/" ? "page" : undefined}>[ laubach.dev ]</a>
        <ul class="states-container">
            <li><a class="state-link" href="/projects" aria-current={currentPath === "/projects" ? "page" : undefined}>Projects</a></li>
            <li><a class="state-link" href="/about" aria-current={currentPath === "/about" ? "page" : undefined}>About</a></li>
            <li><a class="state-link" href="/contact" aria-current={currentPath === "/contact" ? "page" : undefined}>Contact</a></li>
        </ul>
    </div>
</nav>
<style>
    nav {
        position: sticky;
        top: 0;
        z-index: 10;

        /* margin: 0 var(--space-4); */

        padding: var(--space-1) var(--space-4);

        box-shadow: var(--shadow-sm);
        background: var(--color-surface);
    }

    nav a {
        color: inherit;
        text-decoration: none;
    }

    .container {
        display: flex;
        justify-content: space-between;
        align-items: center;

        max-width: var(--max-width-wide);
        margin-inline: auto;
    }

    .wordmark {
        font-family: var(--font-mono);
        font-weight: 600;
        font-size: var(--text-xl);
        white-space: nowrap;
    }

    .states-container {
        display: flex;
        align-items: center;

        list-style: none;

        margin-right: var(--space-1);

        gap: var(--space-12);
    }

    .states-container a {
        transition: color 0.15s ease;
    }

    .states-container a:hover {
        color: var(--color-accent-hover);
    }

    .states-container a[aria-current="page"] {
        font-weight: 600;
    }

    /* mobile styles */
    @media (max-width: 480px) {
    .wordmark {
        font-size: var(--text-base);   /* down from --text-xl */
    }
    .states-container {
        gap: var(--space-3);            /* down from --space-8 */
    }
    nav {
        padding-inline: var(--space-2); /* reclaim edge space */
    }
}

</style>